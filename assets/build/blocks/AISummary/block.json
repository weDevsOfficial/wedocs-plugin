{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wedocs/ai-summary",
  "version": "1.0.0",
  "title": "weDocs AI-Powered Summary",
  "category": "wedocs",
  "icon": "lightbulb",
  "description": "Display an AI-generated summary of documentation content with collapsible functionality.",
  "example": {},
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "wide",
      "full"
    ],
    "color": {
      "background": false,
      "text": false
    },
    "typography": false,
    "spacing": {
      "margin": true,
      "padding": true,
      "__experimentalDefaultControls": {
        "padding": true,
        "margin": true
      }
    }
  },
  "attributes": {
    "blockId": {
      "type": "string",
      "default": ""
    },
    "postId": {
      "type": "number",
      "default": 0
    },
    "title": {
      "type": "string",
      "default": "AI-Powered Summary"
    },
    "content": {
      "type": "string",
      "default": ""
    },
    "isCollapsible": {
      "type": "boolean",
      "default": true
    },
    "isOpenByDefault": {
      "type": "boolean",
      "default": false
    },
    "showIcon": {
      "type": "boolean",
      "default": true
    },
    "iconType": {
      "type": "string",
      "default": "sparkles"
    },
    "backgroundColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "textColor": {
      "type": "string",
      "default": "#000000"
    },
    "titleColor": {
      "type": "string",
      "default": "#000000"
    },
    "titleFontSize": {
      "type": "string",
      "default": "20px"
    },
    "titleFontWeight": {
      "type": "string",
      "default": "600"
    },
    "contentFontSize": {
      "type": "string",
      "default": "16px"
    },
    "borderRadius": {
      "type": "string",
      "default": "8px"
    },
    "borderStyle": {
      "type": "string",
      "default": "solid"
    },
    "borderWidth": {
      "type": "string",
      "default": "1px"
    },
    "borderColor": {
      "type": "string",
      "default": "#000000"
    },
    "padding": {
      "type": "object",
      "default": {
        "top": "20px",
        "right": "20px",
        "bottom": "20px",
        "left": "20px"
      }
    },
    "margin": {
      "type": "object",
      "default": {
        "top": "0px",
        "right": "0px",
        "bottom": "20px",
        "left": "0px"
      }
    }
  },
  "textdomain": "wedocs-plugin",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}
{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wedocs/print-button",
  "version": "1.0.0",
  "title": "Print Button",
  "icon": "printer",
  "category": "wedocs",
  "description": "Add a print button to allow users to print the current page",
  "keywords": [
    "print",
    "button",
    "wedocs",
    "documentation"
  ],
  "supports": {
    "html": false
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "attributes": {
    "layout": {
      "type": "string",
      "default": "layout1"
    },
    "buttonText": {
      "type": "string",
      "default": "Print"
    },
    "showIcon": {
      "type": "boolean",
      "default": true
    },
    "additionalClasses": {
      "type": "string",
      "default": ""
    },
    "typography": {
      "type": "object",
      "default": {
        "desktop": {
          "fontSize": "16px",
          "fontWeight": "normal"
        },
        "tablet": {},
        "mobile": {}
      }
    },
    "padding": {
      "type": "object",
      "default": {
        "desktop": {
          "top": "10px",
          "right": "15px",
          "bottom": "10px",
          "left": "15px"
        },
        "tablet": {},
        "mobile": {}
      }
    },
    "margin": {
      "type": "object",
      "default": {
        "desktop": {
          "top": "0px",
          "right": "0px",
          "bottom": "10px",
          "left": "0px"
        },
        "tablet": {},
        "mobile": {}
      }
    },
    "backgroundColor": {
      "type": "object",
      "default": {
        "desktop": "#0073aa",
        "tablet": "",
        "mobile": ""
      }
    },
    "textColor": {
      "type": "object",
      "default": {
        "desktop": "#ffffff",
        "tablet": "",
        "mobile": ""
      }
    },
    "hoverBackgroundColor": {
      "type": "object",
      "default": {
        "desktop": "#005177",
        "tablet": "",
        "mobile": ""
      }
    },
    "hoverTextColor": {
      "type": "object",
      "default": {
        "desktop": "#ffffff",
        "tablet": "",
        "mobile": ""
      }
    },
    "border": {
      "type": "object",
      "default": {
        "desktop": {
          "radius": "4px",
          "width": "1px",
          "color": "#0073aa",
          "style": "solid"
        },
        "tablet": {},
        "mobile": {}
      }
    }
  }
}